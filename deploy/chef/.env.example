# ============================================================
# Chef AI - Environment Variables Template
# Copy to /opt/chef_ai/server-deno/.env and fill in values
# ============================================================

# Supabase (公司 B 独立项目)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
JWT_SECRET_KEY=your-jwt-secret

# Encryption Key (32+ characters, for encrypting API keys in DB)
ENCRYPTION_KEY=your-32-character-encryption-key

# AI Provider API Keys
ULTRAVOX_API_KEY=your-ultravox-api-key
# Optional: if using other providers
# OPENAI_API_KEY=your-openai-key
# GEMINI_API_KEY=your-gemini-key
# ELEVENLABS_API_KEY=your-elevenlabs-key

# Server Configuration
HOST=127.0.0.1
PORT=8081
DEV_MODE=False
